# --- Supabase 後端 ---
# 到 https://supabase.com 開專案後, 在 Project Settings > API 找到這兩個值
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# 後台寫入 / migrations 用. 千萬不要 commit. 在 Settings > API 找到 service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- 暫時可選 ---
# 後台覆寫今日金價時用的密碼 (Phase 4 後台 UI 會用到)
ADMIN_PASSWORD=change-me

# --- SEO / 上線後可填 ---
# 正式網域 (給 sitemap / robots / OG / canonical URL 用). 例如 https://shinygold.tw
NEXT_PUBLIC_SITE_URL=https://jinshanshan.com

# Google Analytics 4 Measurement ID (G-XXXXXXXXXX). 不填就不啟用 GA.
NEXT_PUBLIC_GA_ID=

# Google Ads 轉換追蹤 ID (AW-XXXXXXXXXX). 在 Google Ads → 工具 → 轉換 → 標記設定 找到. 不填就不裝.
NEXT_PUBLIC_ADS_ID=

# Google Search Console 驗證碼 (meta name="google-site-verification" 的 content 值)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
